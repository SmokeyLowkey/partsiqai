# =============================================================================
# PartsIQ Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@host:5432/partsiq

# NextAuth.js Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=  # Generate with: openssl rand -base64 32

# Upstash Redis (for BullMQ job queue) - SHARED across all orgs
UPSTASH_REDIS_REST_URL=rediss://default:password@host.upstash.io:6379

# Encryption for per-organization credentials storage
CREDENTIALS_ENCRYPTION_KEY=  # Generate with: openssl rand -hex 32

# Encryption for BYOK (Bring Your Own Keys) API keys
ENCRYPTION_SECRET=  # Generate with: openssl rand -base64 32 (minimum 32 characters)

# App Config
JOB_CONCURRENCY=5
EMAIL_POLL_INTERVAL_MINUTES=5
CRON_SECRET=  # Generate with: openssl rand -hex 32
LOG_LEVEL=info  # debug, info, warn, error, fatal

# OAuth URLs (for email setup flow)
GMAIL_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/gmail/callback
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/microsoft/callback

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=partsiq
AWS_REGION=ca-central-1

# Mistral API Key (for OCR and LLM tasks)
MISTRAL_API_KEY=

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Note: Per-organization integration credentials (OpenRouter, Gmail, Pinecone, Neo4j)
# are stored encrypted in the database via the admin settings page.

# Resend API Key (for transactional emails)
RESEND_API_KEY=re_...

# Vapi.ai VoIP Integration
# Webhook secrets only — API keys and phone numbers are managed via Admin → Platform Credentials and Phone Pool
VAPI_WEBHOOK_SECRET=  # Secret for webhook endpoint verification (x-vapi-secret header)
VOIP_WEBHOOK_SECRET=  # Secret for custom LLM endpoint auth (Bearer token)
# Note: VAPI_API_KEY, VAPI_PHONE_NUMBER_ID, and VAPI_ASSISTANT_ID are no longer used as env vars.
# Vapi API key is stored in Admin → Platform Credentials.
# Phone numbers are managed via Admin → Phone Pool (Twilio purchase → Vapi import → pool rotation).
# Twilio credentials (accountSid, authToken) are stored in Admin → Platform Credentials → TWILIO.

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_...  # Use the Project API Key (phc_ prefix), NOT a Personal API Key (phx_)
# Personal API key + project ID — only needed for `pnpm tsx scripts/posthog-setup.ts`
# which provisions dashboards / funnels / cohorts via the PostHog management API.
# Personal key: PostHog → Project Settings → Personal API Keys → scope:project.
# Project ID: PostHog → Project Settings → Project Variables (numeric, not the phc_ token).
POSTHOG_PERSONAL_API_KEY=phx_...
POSTHOG_PROJECT_ID=12345

# Public app URL (used for SEO canonical URLs, sitemap, OG images)
NEXT_PUBLIC_APP_URL=https://partsiqai.com

# ---------------------------------------------------------------------------
# Seed script passwords — required by `prisma db seed` and by
# scripts/create-master-admin.ts. These never go in commit history.
# Use strong passwords; the seed will throw if any are missing.
# ---------------------------------------------------------------------------
MASTER_ADMIN_PASSWORD=       # Strong password for the master admin account
SEED_ADMIN_PASSWORD=         # Demo org admin seed password
SEED_MANAGER_PASSWORD=       # Demo org manager seed password
SEED_MANAGER_EMAIL=          # Optional: override the demo manager email (defaults to manager@demo-construction.com)
SEED_TECHNICIAN_PASSWORD=    # Demo org technician seed password

# ---------------------------------------------------------------------------
# Contact + legal form routing
# All form submissions are sent via Resend to the first configured address.
# Fallback chain: CONTACT_NOTIFICATION_EMAIL → ADMIN_NOTIFICATION_EMAIL →
# LEADS_NOTIFICATION_EMAIL → onboarding@partsiqai.com
# ---------------------------------------------------------------------------
CONTACT_NOTIFICATION_EMAIL=  # Inbox for /contact form submissions
LEGAL_NOTIFICATION_EMAIL=    # Inbox for /terms and /privacy form submissions
LEADS_NOTIFICATION_EMAIL=    # Inbox for blog BlogCTA lead captures
ADMIN_NOTIFICATION_EMAIL=    # Generic fallback admin inbox
